# ===== CONFIGURACIÓN DEL SERVIDOR =====
NODE_ENV=development
# Local: Vite apunta al mismo PORT. Producción (PM2): ver ecosystem.config.cjs (5001) — no confundir con este valor.
PORT=3000
FRONTEND_URL=http://localhost:5173
# Producción (CORS / enlaces): https://www.damecodigo.com

# ===== SPA (Vite): solo archivos ".env.*" en la raíz del repo =====
# `npm run dev` usa .env.local / .env; `vite build` carga también .env.production
# VITE_API_URL=https://www.damecodigo.com
# Dominio o URL base sin terminar en /api (si pones …/api, las rutas quedan /api/api/… y pueden dar 404 HTML).

# ===== MONGODB =====
# MongoDB Local (fallback a Atlas si falla)
MONGODB_URI_LOCAL=mongodb://localhost:27017/link4deal
MONGODB_URI_ATLAS=mongodb+srv://username:password@cluster.mongodb.net/link4deal?retryWrites=true&w=majority
MONGODB_URI_FALLBACK=true

# ===== CLOUDINARY =====
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=link4deal/promotions

# ===== OCR SERVICE =====
# Python OCR Server
OCR_SERVICE_URL=http://localhost:8000
OCR_API_KEY=your_rapidapi_key
OCR_SERVICE_TIMEOUT=30000

# ===== RAPIDAPI =====
RAPIDAPI_KEY=your_rapidapi_key
RAPIDAPI_HOST=ocr.space

# ===== MULTER (FILE UPLOADS) =====
MAX_FILE_SIZE=10485760
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp
# Ruta única de uploads (por defecto: server/uploads). Imágenes de promociones en server/uploads/promotions
# UPLOAD_PATH=./server/uploads

# ===== LUXAE COMPLIANCE (instalaciones app + polígono WGS84 + direcciones Polygon) =====
# CRUD: header X-Luxae-Compliance-Key debe coincidir con este valor.
# LUXAE_COMPLIANCE_API_KEY=
# Opcional: lectura on-chain saldo ERC-20 LUXAE en Polygon (POST .../balances/refresh)
# POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/KEY
# LUXAE_TOKEN_CONTRACT_ADDRESS=0x...
# LUXAE_TOKEN_DECIMALS=18

# ===== SECURITY =====
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Listados GET /api/discount-qr/redemptions/recent, /api/discount-qr/coupons/dashboard y /api/discount-qr/stats/luxae-usd (página «en vivo»). Por IP, ventana 15 min. Por defecto 600.
# REDEMPTIONS_RECENT_RATE_MAX=600
# Si usas el listado, igual clave en servidor y en Vite: REDEMPTIONS_LIST_API_KEY y VITE_REDEMPTIONS_LIST_API_KEY

# Código corto de perfil influencer → buscador app (GET/POST discount-qr/codes) usando una promoción por defecto
# INFLUENCER_PROFILE_SHORT_CODE_DEFAULT_PROMOTION_ID=

# Webhook opcional: POST tras cada canje exitoso (tokens LUXAE / ledger externo). Ver panel redenciones-en-vivo.
# LUXAE_SETTLEMENT_WEBHOOK_URL=
# LUXAE_SETTLEMENT_WEBHOOK_SECRET=
# LUXAE_SETTLEMENT_WEBHOOK_TIMEOUT_MS=8000

# Tras un canje exitoso, extiende expiresAt (TTL Mongo) = fecha del canje + N días. Sin esto, el vencimiento original del QR suele hacer que el documento desaparezca y pierdas auditoría/redenciones en listados.
# QR_REDEEM_RETENTION_DAYS=90

# ===== LOGGING =====
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# ===== CORS =====
CORS_ORIGIN=http://localhost:5173
CORS_CREDENTIALS=true

# ===== ENVIRONMENT SPECIFIC =====
# Development
DEV_MONGODB_URI=mongodb://localhost:27017/link4deal_dev
DEV_CLOUDINARY_FOLDER=link4deal/dev/promotions

# Production
PROD_MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/link4deal_prod
PROD_CLOUDINARY_FOLDER=link4deal/prod/promotions
