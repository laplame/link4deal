# ===== CONFIGURACIÓN DEL SERVIDOR =====
NODE_ENV=development
# Local: Vite apunta al mismo PORT. Producción (PM2): ver ecosystem.config.cjs (5001) — no confundir con este valor.
PORT=3000
FRONTEND_URL=http://localhost:5173
# URL canónica del sitio (sitemap, prerender SEO, Open Graph)
PUBLIC_SITE_URL=https://www.damecodigo.com
# VITE_PUBLIC_SITE_URL=https://www.damecodigo.com
# Google Play — programa de prueba cerrada (testers influencers)
# VITE_PLAY_STORE_TESTING_URL=https://play.google.com/apps/testing/com.damecodigo.app
# Producción (CORS / enlaces): https://www.damecodigo.com

# ===== SPA (Vite): solo archivos ".env.*" en la raíz del repo =====
# `npm run dev` usa .env.local / .env; `vite build` carga también .env.production
# VITE_API_URL=https://www.damecodigo.com
# Google Tag Manager (contenedor web; debe coincidir con index.html si cambias el ID)
# VITE_GTM_ID=GTM-52MGDMBK
# Google Analytics 4 — measurement ID (tag «GA4 Configuration» dentro de GTM, no gtag en HTML)
# VITE_GA4_ID=G-T07TDTRKQ3
# Microsoft Clarity
# VITE_CLARITY_ID=ii79hzm8sb
# Analítica: localhost:5173 (y puertos dev) no se guardan en visitas influencer ni dataLayer
# Dominio o URL base sin terminar en /api (si pones …/api, las rutas quedan /api/api/… y pueden dar 404 HTML).

# ===== MONGODB =====
# MongoDB Local (fallback a Atlas si falla)
MONGODB_URI_LOCAL=mongodb://localhost:27017/link4deal
MONGODB_URI_ATLAS=mongodb+srv://username:password@cluster.mongodb.net/link4deal?retryWrites=true&w=majority
MONGODB_URI_FALLBACK=true

# ===== CLOUDINARY =====
# Opción A (recomendada): una sola URL del dashboard de Cloudinary
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# Opción B: variables sueltas (se usan si CLOUDINARY_URL no está definida)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=link4deal/promotions

# ===== OCR SERVICE =====
# Python OCR Server
OCR_SERVICE_URL=http://localhost:8000
OCR_API_KEY=your_rapidapi_key
OCR_SERVICE_TIMEOUT=30000

# ===== RAPIDAPI =====
RAPIDAPI_KEY=your_rapidapi_key
RAPIDAPI_HOST=ocr.space

# ===== MULTER (FILE UPLOADS) =====
MAX_FILE_SIZE=10485760
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp
# Ruta de uploads (NO dentro del repo en producción — git pull borra server/uploads si estaba versionado).
# Por defecto: server/uploads (promociones → …/promotions, influencers → …/influencers)
# VPS recomendado (fuera del clone git):
# UPLOAD_PATH=/var/data/link4deal/uploads
# Nginx proxy: location ^~ /uploads/ → backend (PM2). Cloudinary = respaldo si el disco falla.
# Scripts: node server/scripts/check-promotion-images-integrity.js
#          node server/scripts/backfill-cloudinary-from-local.js --apply

# ===== LUXAE COMPLIANCE (instalaciones app + polígono WGS84 + direcciones Polygon) =====
# CRUD: header X-Luxae-Compliance-Key debe coincidir con este valor.
# LUXAE_COMPLIANCE_API_KEY=
# Opcional: lectura on-chain saldo ERC-20 LUXAE en Polygon (POST .../balances/refresh)
# POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/KEY
# LUXAE_TOKEN_CONTRACT_ADDRESS=0x...
# LUXAE_TOKEN_DECIMALS=18

# ===== SECURITY =====
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Listados GET /api/discount-qr/redemptions/recent, /api/discount-qr/coupons/dashboard y /api/discount-qr/stats/luxae-usd (página «en vivo»). Por IP, ventana 15 min. Por defecto 600.
# REDEMPTIONS_RECENT_RATE_MAX=600
# Si usas el listado, igual clave en servidor y en Vite: REDEMPTIONS_LIST_API_KEY y VITE_REDEMPTIONS_LIST_API_KEY

# Código corto de perfil influencer → buscador app (GET/POST discount-qr/codes) usando una promoción por defecto
# INFLUENCER_PROFILE_SHORT_CODE_DEFAULT_PROMOTION_ID=

# App influencer: story cards verticales (Nano Banana / Gemini Image). Misma clave que análisis de promos.
# GEMINI_API_KEY=
# GEMINI_STORY_CARD_MODEL=gemini-2.5-flash-image
# GEMINI_NANO_BANANA_MODEL=gemini-2.5-flash-image

# Webhook opcional: POST tras cada canje exitoso (tokens LUXAE / ledger externo). Ver panel redenciones-en-vivo.
# LUXAE_SETTLEMENT_WEBHOOK_URL=
# LUXAE_SETTLEMENT_WEBHOOK_SECRET=
# LUXAE_SETTLEMENT_WEBHOOK_TIMEOUT_MS=8000

# Tras un canje exitoso, extiende expiresAt (TTL Mongo) = fecha del canje + N días. Sin esto, el vencimiento original del QR suele hacer que el documento desaparezca y pierdas auditoría/redenciones en listados.
# QR_REDEEM_RETENTION_DAYS=90

# Abono influencer por canje (ledger Mongo; ver docs/INFLUENCER_TOKEN_SETTLEMENT_MONGO.md)
# INFLUENCER_SETTLEMENT_ENABLED=true
# INFLUENCER_SETTLEMENT_AUTO_PAY_MONGO=false
# INFLUENCER_SETTLEMENT_TOKEN_SYMBOL=LUXAE

# Usuarios demo dashboards (node server/scripts/seed-demo-dashboard-users.js --apply)
# DEMO_USERS_PASSWORD=DemoLink4Deal2026!

# ===== META / INSTAGRAM (leads CRM) =====
# App en developers.facebook.com — productos Instagram Graph API + Webhooks
# META_APP_ID=
# META_APP_SECRET=
# META_GRAPH_API_VERSION=v21.0
# Token que Meta envía al verificar el webhook (GET hub.verify_token)
# META_WEBHOOK_VERIFY_TOKEN=link4deal_ig_webhook_dev
# Debe apuntar al backend público (no al puerto de Vite):
# META_INSTAGRAM_REDIRECT_URI=https://www.damecodigo.com/api/instagram/oauth/callback
# Webhook URL en Meta: https://www.damecodigo.com/api/instagram/webhook
# Campos sugeridos: comments, messages, mentions (objeto instagram)

# ===== LOGGING =====
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# ===== CORS =====
CORS_ORIGIN=http://localhost:5173
CORS_CREDENTIALS=true

# ===== ENVIRONMENT SPECIFIC =====
# Development
DEV_MONGODB_URI=mongodb://localhost:27017/link4deal_dev
DEV_CLOUDINARY_FOLDER=link4deal/dev/promotions

# Production
PROD_MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/link4deal_prod
PROD_CLOUDINARY_FOLDER=link4deal/prod/promotions
