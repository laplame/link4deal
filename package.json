{
  "name": "vite-react-typescript-starter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=18.18.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "NODE_OPTIONS=--max-old-space-size=8192 vite build",
    "build:vps": "NODE_OPTIONS=--max-old-space-size=1536 vite build --mode vps",
    "build:check": "tsc -b",
    "build:full": "pnpm run build:check && pnpm run build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "server": "node server/index.js",
    "server:dev": "nodemon",
    "server:watch": "nodemon",
    "server:start": "node server/index.js",
    "python:install": "cd server_py && python3 -m venv venv && source venv/bin/activate && pip install -r requirements.txt",
    "python:dev": "cd server_py && source venv/bin/activate && python main.py",
    "python:start": "cd server_py && source venv/bin/activate && python main.py",
    "start:all": "concurrently \"pnpm run server:dev\" \"pnpm run python:dev\" \"pnpm run dev\"",
    "db:start": "mongod --dbpath ./data/db",
    "db:stop": "pkill mongod",
    "setup": "pnpm install && pnpm run python:install && mkdir -p data/db server/uploads server/uploads/promotions logs",
    "postinstall": "node scripts/prune-legacy-server-node-modules.cjs",
    "verify-api": "node scripts/verify-api.js",
    "deploy:apk": "bash scripts/deploy-apk.sh",
    "deploy:vps": "bash scripts/deploy-vps-rsync.sh --skip-build",
    "deploy:vps:dist": "bash scripts/deploy-vps-rsync.sh --dist-only --skip-build",
    "deploy:vps:build": "pnpm run build:full && bash scripts/deploy-vps-rsync.sh --skip-build",
    "deploy:vps:src": "bash scripts/deploy-vps-rsync.sh --src-only --skip-build",
    "deploy:vps:print": "bash scripts/deploy-vps-rsync.sh --print-only",
    "watchdog": "bash scripts/server-watchdog.sh",
    "ensure-uploads": "node scripts/ensure-uploads-accessible.cjs",
    "ensure-promotion": "node server/scripts/check-and-ensure-one-promotion.js",
    "check:promo-images": "node server/scripts/check-promotion-images-integrity.js",
    "repair:promo-images": "node server/scripts/repair-promotion-images-from-disk.js",
    "promote:superadmin": "node server/scripts/promote-user-to-super-admin.js",
    "delete:user": "node server/scripts/delete-user-by-email.js",
    "seed:roles": "node server/scripts/seed-roles.js",
    "cleanup:promo-images": "node server/scripts/cleanup-missing-promotion-images.js",
    "seed:influencer-auctions": "node server/scripts/seed-influencer-auctions.js",
    "db:drop-promo-geo-index": "node server/scripts/drop-promotion-2dsphere-index.js",
    "db:delete-all-promotions": "node server/scripts/delete-all-promotions.js",
    "db:redemptions-today": "node server/scripts/list-redemptions-by-day.js"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "cloudinary": "^1.41.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.540.0",
    "mongoose": "^8.0.3",
    "multer": "^1.4.5-lts.1",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.1",
    "recharts": "^2.15.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "core-js", "sharp"]
  },
  "overrides": {
    "vite": "5.4.21"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/google.maps": "^3.58.1",
    "@types/multer": "^1.4.11",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@typescript-eslint/eslint-plugin": "^6.10.0",
    "@typescript-eslint/parser": "^6.10.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.21",
    "concurrently": "^8.2.2",
    "eslint": "^8.53.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.4",
    "nodemon": "^3.0.2",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.2.2",
    "vite": "5.4.21"
  }
}
