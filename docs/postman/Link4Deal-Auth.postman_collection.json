                  "if (id) pm.environment.set('agencyId', id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": { "method": "GET", "header": [], "url": "{{baseUrl}}/api/agencies/mine" }
        },
        {
          "name": "GET /api/agencies/:id/analytics",
          "request": { "method": "GET", "header": [], "url": "{{baseUrl}}/api/agencies/{{agencyId}}/analytics" }
        }
      ]
    },
    {
      "name": "07 — Panel marcas (PIN o super admin JWT)",
      "item": [
        {
          "name": "GET aplicaciones — JWT super admin",
          "auth": {
            "type": "bearer",
            "bearer": [{ "key": "token", "value": "{{token_superadmin}}", "type": "string" }]
          },
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/promotion-applications/brand"
          }
        },
        {
          "name": "GET aplicaciones — PIN (X-Brand-Dashboard-Password)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Brand-Dashboard-Password", "value": "{{brandDashboardPin}}" }
            ],
            "url": "{{baseUrl}}/api/promotion-applications/brand"
          }
        },
        {
          "name": "PATCH aplicación status — super admin JWT",
          "auth": {
            "type": "bearer",
            "bearer": [{ "key": "token", "value": "{{token_superadmin}}", "type": "string" }]
          },
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"approved\"\n}"
            },
            "url": "{{baseUrl}}/api/promotion-applications/{{applicationId}}/status"
          }
        }
      ]
    },
